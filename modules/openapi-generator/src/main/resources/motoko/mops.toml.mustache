[toolchain]
moc = "1.3.0"

[package]
name = "{{artifactId}}"
version = "{{artifactVersion}}"
description = "Generated Motoko client for {{appName}}"
{{#artifactRepoUrl}}repository = "{{artifactRepoUrl}}"
{{/artifactRepoUrl}}license = "Apache-2.0"
files = ["src/Apis/**/*.mo", "src/Models/**/*.mo"]

[dependencies]
core = "2.3.1"
serde-core = "0.0.1"
"cbor@4.1.0" = "4.1.0"
"itertools@0.2.2" = "0.2.2" # because for serde-core
xtended-numbers = "2.3.0"
"xtended-numbers@2.3.0" = "2.3.0" # because for ByteUtils (inlined in serde-core)
base = "0.14.13" # because serde-core uses json.mo submodule
"sha2@0.1.6" = "0.1.6"
