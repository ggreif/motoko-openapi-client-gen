[toolchain]
moc = "1.3.0"

[package]
name = "{{artifactId}}"
version = "{{artifactVersion}}"
description = "Generated Motoko client for {{appName}}"

[dependencies]
core = "https://github.com/caffeinelabs/motoko-core#refs/pull/468/head"
# NOTE: github.com/ggreif/* are temporary forks used during motoko-core transition.
# Replace with official published versions when upstreamed:
#   serde = "3.4.0" (or latest from github.com/NatLabs/serde)
#   byte-utils = "0.1.2" (or latest official version)
serde = "https://github.com/ggreif/serde#core"
"cbor@4.1.0" = "4.1.0"
xtended-numbers = "2.3.0"
"itertools@0.2.2" = "0.2.2" # because for ByteUtils
"byte-utils@0.1.2" = "https://github.com/NatLabs/ByteUtils#refs/pull/3/head" # because for ByteUtils
"base@0.7.3" = "0.14.13" # because serde uses json.mo submodule
"xtended-numbers@2.3.0" = "2.3.0" # because for ByteUtils
"sha2@0.1.6" = "0.1.6"
