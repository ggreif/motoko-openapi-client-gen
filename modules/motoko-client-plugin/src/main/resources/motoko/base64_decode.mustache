        // Inline base64 decoder (standard alphabet, RFC 4648 §4) — temporary stopgap
        // until mo:core/Base64 ships `decode`. `_`-prefixed so it never triggers an
        // unused-identifier warning in modules that import Base64 only for encoding.
        func _decode(input : Text) : ?Blob {
            var acc : Nat32 = 0;
            var nbits : Nat32 = 0;
            let out = List.empty<Nat8>();
            for (ch in input.chars()) {
                if (ch != '=') {
                    let n = Char.toNat32(ch);
                    let v : Nat32 =
                        if (n >= 65 and n <= 90) n - 65
                        else if (n >= 97 and n <= 122) n - 71
                        else if (n >= 48 and n <= 57) n + 4
                        else if (n == 43) 62
                        else if (n == 47) 63
                        else return null;
                    acc := (acc << 6) | v;
                    nbits += 6;
                    if (nbits >= 8) {
                        nbits -= 8;
                        List.add(out, Nat8.fromNat(Nat32.toNat((acc >> nbits) & 0xFF)));
                    };
                };
            };
            ?Blob.fromArray(List.toArray(out));
        };
